# Anthropic API key — required ONLY when you run with --enrich
# (Claude normalizes raw party names into structured contacts).
ANTHROPIC_API_KEY=

# NYC Open Data (Socrata) app token — optional, raises the API rate limit.
# Get one free at:
#   https://data.cityofnewyork.us/profile/edit/developer_settings
SOCRATA_APP_TOKEN=

# Optional dataset overrides (defaults are the standard NYC Open Data IDs).
# ACRIS_MASTER_DATASET=bnx9-e6tj
# ACRIS_LEGALS_DATASET=8h5j-fqxa
# ACRIS_PARTIES_DATASET=636b-3b5g
# DOB_JOBS_DATASET=ic3t-wcy2
